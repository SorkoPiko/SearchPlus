{
	"geode": "5.0.0",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "sorkopiko.searchplus",
	"name": "SearchPlus",
	"version": "v1.0.0",
	"developer": "SorkoPiko",
	"description": "Search faster",
	"links": {
		"source": "https://github.com/SorkoPiko/SearchPlus",
		"community": "https://discord.gg/8uPFxhxBX9"
	},
	"tags": [
		"offline",
		"online",
		"enhancement",
		"interface",
		"utility"
	],
	"dependencies": {
		"geode.node-ids": ">=v1.23.0"
	},
	"settings": {
		"search-category": {
			"name": "Search Settings",
			"type": "title",
			"description": "Control how the search function works."
		},
		"debounceTime": {
			"name": "Debounce Time (ms)",
			"type": "int",
			"default": 350,
			"description": "The amount of time to wait after you stop typing before performing a search (in milliseconds).",
			"min": 100,
			"max": 1000,
			"control": {
				"slider": true
			}
		}
	}
}